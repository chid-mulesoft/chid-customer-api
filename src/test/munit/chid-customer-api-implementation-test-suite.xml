    </munit:test>

    <munit:test name="post-customer-by-id-flow-success" description="Verify that the post-customer-by-id-flow successfully returns success response when updating a customer">
        <munit:behavior>
            <munit:set-event>
                <munit:payload value='{
                    "firstName": "Updated",
                    "lastName": "Customer",
                    "age": 25
                }' mediaType="application/json" />
                <munit:attributes value='{
                    "uriParams": {
                        "id": "12345"
                    },
                    "method": "POST",
                    "requestPath": "/api/customers/12345"
                }' />
            </munit:set-event>
        </munit:behavior>
        <munit:execution>
            <flow-ref name="post-customer-by-id-flow" />
        </munit:execution>
        <munit:validation>
            <munit-tools:assert-that expression="#[payload]" is="#[MunitTools::notNullValue()]" />
            <munit-tools:assert-equals actual="#[payload.message]" expected="Customer updated successfully" />
            <munit-tools:assert-equals actual="#[payload.customerId]" expected="12345" />
            <munit-tools:assert-that expression="#[payload.timestamp]" is="#[MunitTools::notNullValue()]" />
            <munit-tools:assert-that expression="#[sizeOf(payload)]" is="#[MunitTools::equalTo(3)]" />
        </munit:validation>
    </munit:test>

