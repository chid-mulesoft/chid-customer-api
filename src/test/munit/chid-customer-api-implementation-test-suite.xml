    <munit:test name="patch-customer-by-id-flow-firstname-only" description="Verify that the PATCH customer by ID flow successfully updates customer data when provided with valid partial customer data (firstname only) and returns a proper success response">
        <munit:behavior>
            <munit:set-event>
                <munit:payload value='{
                    "firstname": "UpdatedFirstName"
                }' mediaType="application/json" />
                <munit:attributes value='{
                    "uriParams": {
                        "id": "CUST-1001"
                    },
                    "method": "PATCH",
                    "requestPath": "/api/customers/CUST-1001"
                }' />
            </munit:set-event>
        </munit:behavior>
        <munit:execution>
            <flow-ref name="patch-customer-by-id-flow" />
        </munit:execution>
        <munit:validation>
            <munit-tools:assert-that expression="#[payload]" is="#[MunitTools::notNullValue()]" />
            <munit-tools:assert-equals actual="#[payload.successCode]" expected="CUSTOMER_UPDATED" />
            <munit-tools:assert-equals actual="#[payload.customerId]" expected="CUST-1001" />
            <munit-tools:assert-that expression="#[payload.successMessage]" is="#[MunitTools::containsString('CUST-1001')]" />
            <munit-tools:assert-that expression="#[payload.updatedFields]" is="#[MunitTools::notNullValue()]" />
            <munit-tools:assert-that expression="#[payload.timestamp]" is="#[MunitTools::notNullValue()]" />
        </munit:validation>
    </munit:test>

